{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "predit://artifacts/character_qa_report",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "findings": {
      "type": "array",
      "items": {}
    },
    "summary": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "predit://artifacts/character_qa_report.summary",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "characters_reviewed": {
          "type": "integer",
          "minimum": 0
        },
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "suggestions": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "characters_reviewed",
        "critical",
        "suggestions"
      ]
    }
  },
  "required": [
    "summary"
  ]
}
