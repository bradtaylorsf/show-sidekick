{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "show-sidekick://artifacts/render_report",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "output_path": {
      "type": "string"
    },
    "encoding_profile": {
      "type": "string"
    },
    "duration_s": {
      "type": "number",
      "minimum": 0
    },
    "expected_duration_s": {
      "type": "number",
      "minimum": 0
    },
    "drift_s": {
      "type": "number",
      "minimum": 0
    },
    "drift_frames": {
      "type": "number",
      "minimum": 0
    },
    "drift_tolerance_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "within_tolerance": {
      "type": "boolean"
    },
    "clip_trims": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "show-sidekick://artifacts/render_report.clip_trim",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "requested_duration_s": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "actual_duration_s": {
            "type": "number",
            "minimum": 0
          },
          "drift_s": {
            "type": "number",
            "minimum": 0
          },
          "drift_frames": {
            "type": "number",
            "minimum": 0
          },
          "within_tolerance": {
            "type": "boolean"
          }
        },
        "required": [
          "asset_id",
          "requested_duration_s",
          "actual_duration_s",
          "drift_s",
          "drift_frames",
          "within_tolerance"
        ]
      }
    },
    "resolution": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "show-sidekick://artifacts/resolution",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "width",
        "height"
      ]
    },
    "framerate": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "runtime_used": {
      "type": "string",
      "enum": [
        "ffmpeg",
        "remotion",
        "hyperframes"
      ]
    },
    "asset_count": {
      "type": "integer",
      "minimum": 0
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_steps": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "show-sidekick://artifacts/render_report.validation_step",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "status"
        ]
      }
    }
  },
  "required": [
    "output_path",
    "encoding_profile",
    "duration_s",
    "resolution",
    "framerate",
    "runtime_used",
    "asset_count"
  ]
}
