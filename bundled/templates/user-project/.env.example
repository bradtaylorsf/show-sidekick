# predit provider and tool configuration
#
# `predit init` copies this file to `.env`. Keep `.env.example` committed so
# collaborators and agents know what can be configured. Never commit `.env`;
# it is gitignored because it may contain API keys.
#
# Non-technical users: start with OPENAI_API_KEY, ELEVENLABS_API_KEY, and
# `higgsfield auth login`. Everything else is optional until a video asks for it.
#
# Technical users: exported shell variables win over values in this file.
# predit loads `.env`, `.env.<command>`, and `.env.local` from the project root.
#
# Agents: do not print, echo, log, commit, or screenshot secret values. Use
# `predit doctor --profile paid-demo --json` and `predit ls tools --json` to
# report readiness. Ask before installing CLIs or spending provider credits.

# ---------------------------------------------------------------------------
# First paid-demo path
# ---------------------------------------------------------------------------
# OpenAI direct image fallback and OpenAI TTS fallback.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs premium narration.
# API docs: https://elevenlabs.io/docs/api-reference/authentication
ELEVENLABS_API_KEY=

# Higgsfield GPT Image 2 stills and image-to-video use CLI login by default:
#   npm i -g @higgsfield/cli
#   higgsfield auth login
# CLI docs/source: https://github.com/higgsfield-ai/cli
#
# Advanced recorded-HTTP mode can also use header credentials.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# Local composition runtimes:
#   predit setup runtimes
# installs Remotion and HyperFrames in this project. FFmpeg must be on PATH.

# ---------------------------------------------------------------------------
# Image generation
# ---------------------------------------------------------------------------
# Black Forest Labs FLUX.
# Docs: https://docs.bfl.ai/get-started
BFL_API_KEY=

# Recraft image generation.
# Docs: https://www.recraft.ai/docs/api-reference/getting-started
RECRAFT_API_KEY=

# xAI / Grok image generation.
# Docs: https://docs.x.ai/docs/tutorial
XAI_API_KEY=

# Google Imagen through service-account credentials.
# Docs: https://cloud.google.com/docs/authentication/client-libraries
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CLOUD_PROJECT=

# ---------------------------------------------------------------------------
# TTS and narration
# ---------------------------------------------------------------------------
# Google TTS and Veo share GOOGLE_API_KEY.
# Google AI Studio key page: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Doubao TTS.
# Provider console: https://console.volcengine.com/
DOUBAO_API_KEY=
DOUBAO_APP_ID=

# Local WhisperX/pyannote diarization can use a Hugging Face token.
# Hugging Face tokens: https://huggingface.co/settings/tokens
HF_TOKEN=

# ---------------------------------------------------------------------------
# Video generation and avatar video
# ---------------------------------------------------------------------------
# Runway API.
# Docs: https://docs.dev.runwayml.com/guides/setup/
RUNWAY_API_KEY=

# HeyGen avatar/talking-head video.
# Docs: https://docs.heygen.com/reference/
HEYGEN_API_KEY=

# Replicate-backed video models: CogVideo, Hunyuan, Seedance, Wan.
# Docs: https://replicate.com/docs/topics/security/api-tokens/
REPLICATE_API_TOKEN=

# Kling video API.
# Provider docs/dashboard: https://klingapi.com/docs
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# MiniMax video API.
# Docs: https://platform.minimax.io/docs/guides/quickstart
MINIMAX_API_KEY=

# ByteDance / Seedance direct API.
# Console: https://console.volcengine.com/
BYTEDANCE_API_KEY=

# Modal-hosted LTX video endpoint.
# Modal tokens: https://modal.com/settings/tokens
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_LTX_URL=

# Local diffusion/image model path.
PREDIT_LOCAL_SD_MODEL=

# Whisper.cpp model path override.
WHISPER_MODEL=

# ---------------------------------------------------------------------------
# Music and sound search
# ---------------------------------------------------------------------------
# Suno-compatible music provider.
# Provider docs: https://docs.sunoapi.org/suno-api/quickstart
SUNO_API_KEY=

# Freesound search.
# Docs: https://freesound.org/docs/api/overview.html
FREESOUND_API_KEY=

# Pixabay image, video, and music search.
# Docs: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Pexels stock video/image search.
# Docs: https://www.pexels.com/api/
PEXELS_API_KEY=

# Unsplash stock image search.
# Docs: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Optional curated feed manifests. Values should be URLs to JSON feed files you
# maintain or trust; leave blank unless you know you need these sources.
MIXKIT_FEED_URL=
COVERR_FEED_URL=
DAREFUL_FEED_URL=
POND5_PD_FEED_URL=
VIDEVO_FEED_URL=
NOAA_FEED_URL=
JAXA_FEED_URL=

# No-key public sources in the registry include Archive.org, NASA, ESA, the
# Library of Congress, NARA, and Wikimedia. They do not need env vars.

# ---------------------------------------------------------------------------
# Hosting and handoff helpers
# ---------------------------------------------------------------------------
# Cloudflare R2 image/video hosting.
# Docs: https://developers.cloudflare.com/r2/api/tokens/
PREDIT_R2_BUCKET=
PREDIT_R2_ACCOUNT_ID=
PREDIT_R2_ACCESS_KEY_ID=
PREDIT_R2_SECRET_ACCESS_KEY=
PREDIT_R2_PUBLIC_BASE_URL=

# AWS S3 image/video hosting.
# Docs: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html
PREDIT_S3_BUCKET=
PREDIT_S3_PUBLIC_BASE_URL=
PREDIT_S3_PRESIGN_EXPIRES_S=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---------------------------------------------------------------------------
# Optional third-party runtimes, CLIs, and local binaries
# ---------------------------------------------------------------------------
# These are usually installed with your package manager instead of configured
# here. Run `predit ls tools --json` for exact readiness and install hints.
#
# ffmpeg / ffprobe: media assembly and probing.
#   macOS: brew install ffmpeg
#   Linux: sudo apt-get install ffmpeg
#   Windows: winget install Gyan.FFmpeg
#
# Remotion / HyperFrames:
#   predit setup runtimes
#
# Other optional tools used by specialized pipelines:
#   higgsfield, yt-dlp, aubio, piper, whisper-cli, cap, manim, mmdc,
#   python3 with opencv-python/open_clip_torch/diffusers/torch/accelerate.
#
# Remotion map overlays, when a custom composition asks for Mapbox.
# Docs: https://docs.mapbox.com/help/dive-deeper/access-tokens/
REMOTION_MAPBOX_TOKEN=
