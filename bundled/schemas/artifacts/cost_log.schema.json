{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "show-sidekick://artifacts/cost_log",
  "type": "array",
  "items": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "show-sidekick://artifacts/cost_log.entry",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "tool": {
        "type": "string"
      },
      "provider": {
        "type": "string"
      },
      "model": {
        "type": "string"
      },
      "units": {
        "type": "number",
        "minimum": 0
      },
      "usd": {
        "type": "number",
        "minimum": 0
      },
      "mode": {
        "type": "string",
        "enum": [
          "sample",
          "full"
        ]
      },
      "cache_hit": {
        "type": "boolean"
      }
    },
    "required": [
      "tool",
      "provider",
      "model",
      "units",
      "usd",
      "mode"
    ]
  }
}
