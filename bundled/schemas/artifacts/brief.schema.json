{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "show-sidekick://artifacts/brief",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "tone": {
      "type": "string"
    },
    "duration_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "hook": {
      "type": "string"
    },
    "key_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "audience",
    "platform",
    "tone",
    "duration_s",
    "hook"
  ]
}
