{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "predit://artifacts/research-brief",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "topic_exploration": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "predit://artifacts/source",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "accessed_at": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "predit://artifacts/finding",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "claim": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "claim"
        ]
      }
    }
  },
  "required": [
    "topic_exploration",
    "sources",
    "findings"
  ]
}
