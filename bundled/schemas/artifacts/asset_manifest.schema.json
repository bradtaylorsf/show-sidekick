{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "predit://artifacts/asset-manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "assets": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "predit://artifacts/asset",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "scene_ref": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "seed": {
            "type": "integer"
          },
          "prompt": {
            "type": "string"
          },
          "cost_usd": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "id",
          "kind",
          "path"
        ]
      }
    }
  },
  "required": [
    "assets"
  ]
}
