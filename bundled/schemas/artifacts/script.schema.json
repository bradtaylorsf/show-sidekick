{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "predit://artifacts/script",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "predit://artifacts/script-section",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "hook",
              "setup",
              "inciting_incident",
              "rising_action",
              "beat_drop",
              "climax",
              "falling_action",
              "resolution",
              "tag",
              "transition"
            ]
          },
          "start_s": {
            "type": "number",
            "minimum": 0
          },
          "end_s": {
            "type": "number",
            "minimum": 0
          },
          "timing_anchor": {
            "type": "string"
          },
          "timing_source": {
            "type": "string",
            "enum": [
              "lyric",
              "word",
              "beat",
              "section",
              "climax",
              "manual",
              "audio_energy"
            ]
          },
          "timing_ref": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "predit://artifacts/timing-ref",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lyric_line_id": {
                "type": "string"
              },
              "word_id": {
                "type": "string"
              },
              "beat_index": {
                "type": "integer",
                "minimum": 0
              },
              "climax_index": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": []
          },
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "narration": {
            "type": "string"
          },
          "dialogue": {
            "type": "array",
            "items": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "predit://artifacts/dialogue-line",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "character": {
                  "type": "string"
                },
                "line": {
                  "type": "string"
                }
              },
              "required": [
                "character",
                "line"
              ]
            }
          },
          "enhancement_cues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "slug",
          "start_s",
          "end_s"
        ]
      }
    }
  },
  "required": [
    "sections"
  ]
}
