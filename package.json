{
  "name": "show-sidekick",
  "version": "0.0.0",
  "description": "Show-first AI pre-production for video — build the rough cut, finish in your NLE.",
  "type": "module",
  "bin": {
    "showkick": "./dist/cli/index.js",
    "show-sidekick": "./dist/cli/index.js",
    "showsidekick": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "bundled",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:schemas": "pnpm build && node scripts/generate-artifact-schemas.mjs",
    "dev": "tsx watch src/cli/index.ts",
    "lint": "node scripts/lint.ts",
    "format": "node scripts/format.ts",
    "prepare": "node scripts/install-husky.mjs",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke/framework-smoke.test.ts tests/smoke/starter-sample.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release:check": "node --import tsx scripts/public-flip-checklist.ts --with-e2e",
    "release:check:full": "node --import tsx scripts/public-flip-checklist.ts --with-build --with-e2e",
    "release:smoke:pack": "pnpm build && SHOW_SIDEKICK_PACKED_TARBALL_SMOKE=1 vitest run tests/release/packed-tarball-smoke.test.ts",
    "demo-matrix": "node --import tsx/esm scripts/demo-matrix.ts",
    "docs:providers": "node --import tsx/esm scripts/generate-providers-doc.ts",
    "docs:providers:check": "node --import tsx/esm scripts/generate-providers-doc.ts --check",
    "show-types:check": "node --import tsx/esm scripts/show-types-check.ts",
    "show-types:matrix": "node --import tsx/esm scripts/show-types-matrix.ts",
    "changeset": "pnpm dlx @changesets/cli",
    "changeset:status": "pnpm dlx @changesets/cli status --since=origin/main",
    "changeset:version": "pnpm dlx @changesets/cli version",
    "changeset:publish": "pnpm build && npm publish --provenance --access public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0"
}
