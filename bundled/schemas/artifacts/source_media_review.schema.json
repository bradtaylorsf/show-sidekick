{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "predit://artifacts/source_media_review",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "predit://artifacts/source_media_review.file",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "reviewed": {
            "type": "boolean"
          },
          "technical_probe": {
            "type": "object",
            "additionalProperties": true
          },
          "content_summary": {
            "type": "string"
          },
          "planning_implications": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "path",
          "reviewed",
          "technical_probe",
          "content_summary"
        ]
      }
    }
  },
  "required": [
    "files"
  ]
}
