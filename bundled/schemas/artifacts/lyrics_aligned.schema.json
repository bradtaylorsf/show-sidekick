{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "predit://artifacts/lyrics_aligned",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "enum": [
        "transcript_words",
        "manual",
        "mixed"
      ]
    },
    "lines": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "predit://artifacts/lyrics_aligned.line",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0
          },
          "matched_word_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "start_s": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "end_s": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "start_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "end_ms": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "source": {
            "type": "string",
            "enum": [
              "aligned",
              "gap_filled",
              "manual",
              "unmatched"
            ]
          },
          "flagged": {
            "type": "boolean"
          }
        },
        "required": [
          "text",
          "confidence",
          "matched_word_ids",
          "start_s",
          "end_s",
          "start_ms",
          "end_ms",
          "source",
          "flagged"
        ]
      }
    }
  },
  "required": [
    "source",
    "lines"
  ]
}
