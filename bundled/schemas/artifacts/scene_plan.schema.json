{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "show-sidekick://artifacts/scene-plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "show-sidekick://artifacts/scene",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string"
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "start_s": {
            "type": "number",
            "minimum": 0
          },
          "end_s": {
            "type": "number",
            "minimum": 0
          },
          "timing_anchor": {
            "type": "string"
          },
          "timing_source": {
            "type": "string",
            "enum": [
              "lyric",
              "word",
              "beat",
              "section",
              "climax",
              "manual",
              "audio_energy"
            ]
          },
          "timing_ref": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "show-sidekick://artifacts/timing-ref",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lyric_line_id": {
                "type": "string"
              },
              "word_id": {
                "type": "string"
              },
              "beat_index": {
                "type": "integer",
                "minimum": 0
              },
              "climax_index": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": []
          },
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "narrative_role": {
            "type": "string",
            "enum": [
              "hook",
              "setup",
              "inciting_incident",
              "rising_action",
              "beat_drop",
              "climax",
              "falling_action",
              "resolution",
              "tag",
              "transition"
            ]
          },
          "scene_anchor": {
            "type": "string"
          },
          "hero_moment": {
            "type": "boolean"
          },
          "slide_id": {
            "type": "string"
          },
          "slide_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "treatment": {
            "type": "string",
            "enum": [
              "slide_image",
              "zoom_pan",
              "highlight",
              "callout",
              "caption",
              "support_visual"
            ]
          },
          "focus_rect": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "show-sidekick://artifacts/slide-rect",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "y": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "width": {
                "type": "number",
                "exclusiveMinimum": 0,
                "maximum": 1
              },
              "height": {
                "type": "number",
                "exclusiveMinimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "x",
              "y",
              "width",
              "height"
            ]
          },
          "highlights": {
            "type": "array",
            "items": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "show-sidekick://artifacts/slide-highlight",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "rect": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "$id": "show-sidekick://artifacts/slide-rect",
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "x": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "y": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    },
                    "height": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    }
                  },
                  "required": [
                    "x",
                    "y",
                    "width",
                    "height"
                  ]
                },
                "shape": {
                  "type": "string",
                  "enum": [
                    "rect",
                    "ellipse"
                  ]
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "rect"
              ]
            }
          },
          "callouts": {
            "type": "array",
            "items": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "show-sidekick://artifacts/slide-callout",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "text": {
                  "type": "string"
                },
                "target_rect": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "$id": "show-sidekick://artifacts/slide-rect",
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "x": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "y": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    },
                    "height": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    }
                  },
                  "required": [
                    "x",
                    "y",
                    "width",
                    "height"
                  ]
                },
                "anchor": {
                  "type": "string",
                  "enum": [
                    "top",
                    "right",
                    "bottom",
                    "left"
                  ]
                }
              },
              "required": [
                "text"
              ]
            }
          },
          "caption": {
            "type": "string"
          },
          "texture_keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "character_actions": {
            "type": "array",
            "items": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "show-sidekick://artifacts/character-action",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "character": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                }
              },
              "required": [
                "character",
                "action"
              ]
            }
          },
          "shot_language": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "show-sidekick://artifacts/shot-language",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "shot_size": {
                "type": "string",
                "enum": [
                  "ECU",
                  "CU",
                  "MCU",
                  "MS",
                  "MLS",
                  "LS",
                  "WS",
                  "EWS",
                  "OTS",
                  "POV"
                ]
              },
              "camera_movement": {
                "type": "string",
                "enum": [
                  "static",
                  "pan_left",
                  "pan_right",
                  "tilt_up",
                  "tilt_down",
                  "dolly_in",
                  "dolly_out",
                  "truck_left",
                  "truck_right",
                  "crane_up",
                  "crane_down",
                  "orbit_cw",
                  "orbit_ccw",
                  "push_in",
                  "pull_out",
                  "handheld",
                  "gimbal_walk",
                  "whip_pan"
                ]
              },
              "lighting_key": {
                "type": "string",
                "enum": [
                  "high_key",
                  "low_key",
                  "natural",
                  "golden_hour",
                  "blue_hour",
                  "neon",
                  "practical",
                  "motivated",
                  "soft",
                  "hard",
                  "rim"
                ]
              },
              "lens_mm": {
                "type": "number",
                "enum": [
                  14,
                  24,
                  35,
                  50,
                  85,
                  135,
                  200
                ]
              },
              "depth_of_field": {
                "type": "string",
                "enum": [
                  "shallow",
                  "deep",
                  "rack_focus"
                ]
              },
              "color_temperature": {
                "type": "string",
                "enum": [
                  "tungsten",
                  "daylight",
                  "mixed",
                  "monochrome"
                ]
              }
            },
            "required": [
              "shot_size",
              "camera_movement",
              "lighting_key",
              "lens_mm",
              "depth_of_field",
              "color_temperature"
            ]
          },
          "required_assets": {
            "type": "array",
            "items": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "show-sidekick://artifacts/required-asset",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string"
                },
                "source": {
                  "type": "string",
                  "enum": [
                    "generated",
                    "stock",
                    "captured",
                    "supplied"
                  ]
                },
                "notes": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "source"
              ]
            }
          }
        },
        "required": [
          "slug",
          "order",
          "start_s",
          "end_s",
          "narrative_role",
          "scene_anchor",
          "shot_language"
        ]
      }
    }
  },
  "required": [
    "scenes"
  ]
}
