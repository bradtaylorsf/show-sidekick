{
  "name": "predit",
  "version": "0.0.0",
  "description": "AI pre-production for video — build the rough cut, finish in your NLE.",
  "type": "module",
  "bin": {
    "predit": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:schemas": "pnpm build && node scripts/generate-artifact-schemas.mjs",
    "dev": "tsx watch src/cli/index.ts",
    "lint": "node scripts/lint.ts",
    "format": "node scripts/format.ts",
    "prepare": "node scripts/install-husky.mjs",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke/framework-smoke.test.ts tests/smoke/starter-sample.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release:check": "node --import tsx scripts/public-flip-checklist.ts --with-e2e",
    "release:check:full": "node --import tsx scripts/public-flip-checklist.ts --with-build --with-e2e",
    "audit:coverage-drift": "node scripts/audit-coverage-drift.ts",
    "audit:l3v-drift": "node scripts/audit-l3v-drift.ts",
    "docs:providers": "node --import tsx/esm scripts/generate-providers-doc.ts",
    "docs:providers:check": "node --import tsx/esm scripts/generate-providers-doc.ts --check"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0"
}
