{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "show-sidekick://artifacts/cuesheet",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "audio": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "show-sidekick://artifacts/cuesheet.audio",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "duration_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "sample_rate": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "channels": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "path",
        "duration_s",
        "sample_rate",
        "channels"
      ]
    },
    "master_clock": {
      "type": "string",
      "enum": [
        "audio",
        "voiceover"
      ]
    },
    "bpm": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "words": {
      "type": "array",
      "items": {}
    },
    "segments": {
      "type": "array",
      "items": {}
    },
    "sections": {
      "type": "array",
      "items": {}
    },
    "beats": {
      "type": "array",
      "items": {}
    },
    "climax": {
      "type": "array",
      "items": {}
    },
    "scene_anchors": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "show-sidekick://artifacts/cuesheet.scene_anchor",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "scene_id": {
            "type": "string"
          },
          "start_s": {
            "type": "number",
            "minimum": 0
          },
          "end_s": {
            "type": "number",
            "minimum": 0
          },
          "snapped_to": {
            "type": "string",
            "enum": [
              "section_start",
              "beat",
              "downbeat",
              "word",
              "climax",
              "manual"
            ]
          },
          "slide_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^slide_\\d{4}$"
            }
          },
          "source": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "show-sidekick://artifacts/cuesheet.scene_anchor.source",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "section": {
                "type": "string"
              },
              "lyric_line_id": {
                "type": "string"
              },
              "beat_index": {
                "type": "integer",
                "minimum": 0
              },
              "word_id": {
                "type": "string"
              },
              "climax_index": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": []
          }
        },
        "required": [
          "scene_id",
          "start_s",
          "end_s",
          "snapped_to",
          "source"
        ]
      }
    }
  },
  "required": [
    "audio",
    "master_clock",
    "segments",
    "sections",
    "beats",
    "climax",
    "scene_anchors"
  ]
}
