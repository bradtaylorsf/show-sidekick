{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "show-sidekick://artifacts/edit_decisions",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "cuts": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "show-sidekick://artifacts/edit_decisions.cut",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "start_s": {
            "type": "number",
            "minimum": 0
          },
          "end_s": {
            "type": "number",
            "minimum": 0
          },
          "timing_anchor": {
            "type": "string"
          },
          "timing_source": {
            "type": "string",
            "enum": [
              "lyric",
              "word",
              "beat",
              "section",
              "climax",
              "manual",
              "audio_energy"
            ]
          },
          "timing_ref": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "show-sidekick://artifacts/timing_ref",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lyric_line_id": {
                "type": "string"
              },
              "word_id": {
                "type": "string"
              },
              "beat_index": {
                "type": "integer",
                "minimum": 0
              },
              "climax_index": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": []
          },
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "asset_id": {
            "type": "string"
          },
          "scene_id": {
            "type": "string"
          },
          "scene_kind": {
            "type": "string",
            "enum": [
              "video_clip",
              "image",
              "slide_scene",
              "comparison",
              "callout",
              "text_card",
              "stat_card",
              "support_visual"
            ]
          },
          "slide_id": {
            "type": "string"
          },
          "slide_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "focus_rect": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "show-sidekick://artifacts/slide_rect",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "y": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "width": {
                "type": "number",
                "exclusiveMinimum": 0,
                "maximum": 1
              },
              "height": {
                "type": "number",
                "exclusiveMinimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "x",
              "y",
              "width",
              "height"
            ]
          },
          "motion": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "show-sidekick://artifacts/edit_decisions.cut.motion",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "push_in",
                  "pull_out",
                  "pan_left",
                  "pan_right",
                  "pan_up",
                  "pan_down",
                  "static"
                ]
              },
              "zoom_start": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "zoom_end": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": []
          },
          "highlights": {
            "type": "array",
            "items": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "show-sidekick://artifacts/slide_highlight",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "rect": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "$id": "show-sidekick://artifacts/slide_rect",
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "x": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "y": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    },
                    "height": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    }
                  },
                  "required": [
                    "x",
                    "y",
                    "width",
                    "height"
                  ]
                },
                "shape": {
                  "type": "string",
                  "enum": [
                    "rect",
                    "ellipse"
                  ]
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "rect"
              ]
            }
          },
          "callouts": {
            "type": "array",
            "items": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "show-sidekick://artifacts/slide_callout",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "text": {
                  "type": "string"
                },
                "target_rect": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "$id": "show-sidekick://artifacts/slide_rect",
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "x": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "y": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    },
                    "height": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "maximum": 1
                    }
                  },
                  "required": [
                    "x",
                    "y",
                    "width",
                    "height"
                  ]
                },
                "anchor": {
                  "type": "string",
                  "enum": [
                    "top",
                    "right",
                    "bottom",
                    "left"
                  ]
                }
              },
              "required": [
                "text"
              ]
            }
          },
          "caption": {
            "type": "string"
          },
          "transition_in": {
            "type": "string"
          },
          "transition_out": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        },
        "required": [
          "start_s",
          "end_s",
          "asset_id"
        ]
      }
    },
    "overlays": {
      "type": "array",
      "items": {}
    },
    "subtitles": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "show-sidekick://artifacts/edit_decisions.subtitles",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "source": {
          "type": "string"
        }
      },
      "required": []
    },
    "audio": {
      "type": "object",
      "additionalProperties": true
    },
    "music": {},
    "transitions": {
      "type": "array",
      "items": {}
    },
    "render_runtime": {
      "type": "string",
      "enum": [
        "ffmpeg",
        "remotion",
        "hyperframes"
      ]
    },
    "renderer_family": {
      "type": "string",
      "enum": [
        "explainer-data",
        "explainer-teacher",
        "cinematic-trailer",
        "documentary-montage",
        "product-reveal",
        "screen-demo",
        "presenter",
        "animation-first"
      ]
    },
    "brand": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "show-sidekick://artifacts/edit_decisions.brand",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "slug",
        "name"
      ]
    }
  },
  "required": [
    "cuts",
    "render_runtime",
    "renderer_family"
  ]
}
